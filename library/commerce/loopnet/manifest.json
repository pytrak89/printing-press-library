{
  "manifest_version": "0.3",
  "name": "loopnet-pp-mcp",
  "display_name": "Loopnet",
  "version": "4.9.0",
  "description": "Loopnet API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/loopnet-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/loopnet-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
